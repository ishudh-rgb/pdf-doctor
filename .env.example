NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PDF Doctor
# Design locked: Theme A + Layout B. Set true only to re-enable Preview Lab.
NEXT_PUBLIC_DESIGN_PREVIEW=false
# Cloud file pickers (Google Drive + Dropbox) on tool pages
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_api_key
NEXT_PUBLIC_DROPBOX_APP_KEY=your_dropbox_app_key
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
MAX_FREE_FILE_SIZE_MB=25
MAX_PRO_FILE_SIZE_MB=100
FILE_RETENTION_HOURS=2
# Max parallel heavy conversions (Excel/Word/Puppeteer/Python) — protects RAM
MAX_CONCURRENT_HEAVY_JOBS=2
# Max upload body size for Next.js proxy (MB)
MAX_UPLOAD_BODY_MB=110
# Separate Razorpay webhook secret (dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
# Salt for hashing guest IPs in usage logs
IP_HASH_SALT=change_me_in_production
# Browser-first merge/split/rotate (server API kept as fallback). Set false to force server.
NEXT_PUBLIC_CLIENT_PDF_TOOLS=true

# Custom brand logo (place files in /public)
# NEXT_PUBLIC_BRAND_LOGO=/logo.png
# NEXT_PUBLIC_BRAND_LOGO_ICON=/logo-icon.png
# NEXT_PUBLIC_BRAND_LOGO_SHOW_TEXT=true

# Logo compare switcher (dev: on by default; set true in prod for preview)
# NEXT_PUBLIC_LOGO_PREVIEW=true
ADMIN_EMAIL=admin@pdfdoctor.com
CRON_SECRET=your_random_secret_here
# Optional: Upstash Redis for distributed rate limiting in production (recommended on Vercel)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional: ConvertAPI secret for Smallpdf-class PDF→Word (https://www.convertapi.com)
# CONVERTAPI_SECRET=your_convertapi_secret

# High-quality local PDF→Word (pdf2docx). Optional explicit Python path:
# PDF2DOCX_PYTHON=python
