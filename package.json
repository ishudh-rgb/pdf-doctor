{
  "name": "pdf-doctor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:all": "npm run test && npm run test:e2e",
    "audit:ci": "npm audit --audit-level=high",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\""
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.25.0",
    "tar": "^7.5.16",
    "exceljs": {
      "uuid": "^11.1.1"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@napi-rs/canvas": "^1.0.0",
    "@pdfsmaller/pdf-decrypt": "^1.0.1",
    "@pdfsmaller/pdf-encrypt": "^1.0.2",
    "@sentry/nextjs": "^10.60.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@types/archiver": "^7.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "archiver": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.2.1",
    "docx": "^9.7.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "libreoffice-convert": "^1.8.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "muhammara": "^6.0.5",
    "next": "16.2.9",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "ppt-to-text": "^1.0.1",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^25.0.4",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "xlsx": "npm:@e965/xlsx@^0.20.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
